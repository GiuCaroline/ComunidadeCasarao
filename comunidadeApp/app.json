{
  "expo": {
    "name": "Comunidade Casarão",
    "slug": "comunidadecasarao",
    "scheme": "comunidadecasarao",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.giucaroline.comunidadecasarao"
    },
    "android": {
      "package": "com.giucaroline.comunidadecasarao",
      "adaptiveIcon": {
        "softwareKeyboardLayoutMode": "resize",
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-video",
      "expo-web-browser"
    ]
  }
}